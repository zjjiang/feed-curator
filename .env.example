# 复制为 .env 并填入真实值(.env 不会被提交)。
#
# === 容器部署(推荐,见 docs/deployment.md)===
# 数据库走 db-mp 容器(feed-net 网络,服务名直连)。
DATABASE_URL="mysql+pymysql://feed_curator:PASSWORD@db-mp:3306/feed_curator?charset=utf8mb4"
# we-mp-rss 在宿主机 :9001,容器经 host.docker.internal 访问。
WEWE_BASE_URL="http://host.docker.internal:9001"

# === 本机直跑(备选)===
# 数据库务必用 127.0.0.1 而非 localhost(见 CLAUDE.md 双 MySQL 说明)。
# 不设置 DATABASE_URL 时 app 回退到本地 SQLite(data/feed-curator.db)。
# DATABASE_URL="mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/feed_curator?charset=utf8mb4"

# DeepSeek API key。留空则只抓取、不做 AI 处理。
DEEPSEEK_API_KEY=""
